package com.telemune.marketplace.rest.entity.vo;

public class TransferValidityDetail {
	private Integer minVolume;

	private Integer maxVolume;

	private Integer type;
	
	private Integer validityDays;

	/**
	 * @return the minVolume
	 */
	public Integer getMinVolume() {
		return minVolume;
	}

	/**
	 * @return the maxVolume
	 */
	public Integer getMaxVolume() {
		return maxVolume;
	}

	/**
	 * @return the type
	 */
	public Integer getType() {
		return type;
	}

	/**
	 * @return the validityDays
	 */
	public Integer getValidityDays() {
		return validityDays;
	}

	/**
	 * @param minVolume the minVolume to set
	 */
	public void setMinVolume(Integer minVolume) {
		this.minVolume = minVolume;
	}

	/**
	 * @param maxVolume the maxVolume to set
	 */
	public void setMaxVolume(Integer maxVolume) {
		this.maxVolume = maxVolume;
	}

	/**
	 * @param type the type to set
	 */
	public void setType(Integer type) {
		this.type = type;
	}

	/**
	 * @param validityDays the validityDays to set
	 */
	public void setValidityDays(Integer validityDays) {
		this.validityDays = validityDays;
	}

	/* (non-Javadoc)
	 * @see java.lang.Object#toString()
	 */
	@Override
	public String toString() {
		return "TransferValidityDetail [minVolume=" + minVolume + ", maxVolume=" + maxVolume + ", type=" + type
				+ ", validityDays=" + validityDays + "]";
	}
	
	

}
