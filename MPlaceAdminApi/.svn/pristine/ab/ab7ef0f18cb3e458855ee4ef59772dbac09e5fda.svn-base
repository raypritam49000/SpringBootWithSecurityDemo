package com.telemune.marketplace.rest.entity.vo;

public class MplaceCustCareRetentionReportVO {
	
	
	private String reportDate;
	
	private Integer totalCallsCount;

	private Integer totalUniqueCallCount;

	private Integer callBackCounts;

	private Double callBackPercentage;

	/**
	 * @return the reportDate
	 */
	public final String getReportDate() {
		return reportDate;
	}

	/**
	 * @return the totalCallsCount
	 */
	public final Integer getTotalCallsCount() {
		return totalCallsCount;
	}

	/**
	 * @return the totalUniqueCallCount
	 */
	public final Integer getTotalUniqueCallCount() {
		return totalUniqueCallCount;
	}

	/**
	 * @return the callBackCounts
	 */
	public final Integer getCallBackCounts() {
		return callBackCounts;
	}

	/**
	 * @return the callBackPercentage
	 */
	public final Double getCallBackPercentage() {
		return callBackPercentage;
	}

	/**
	 * @param reportDate the reportDate to set
	 */
	public final void setReportDate(String reportDate) {
		this.reportDate = reportDate;
	}

	/**
	 * @param totalCallsCount the totalCallsCount to set
	 */
	public final void setTotalCallsCount(Integer totalCallsCount) {
		this.totalCallsCount = totalCallsCount;
	}

	/**
	 * @param totalUniqueCallCount the totalUniqueCallCount to set
	 */
	public final void setTotalUniqueCallCount(Integer totalUniqueCallCount) {
		this.totalUniqueCallCount = totalUniqueCallCount;
	}

	/**
	 * @param callBackCounts the callBackCounts to set
	 */
	public final void setCallBackCounts(Integer callBackCounts) {
		this.callBackCounts = callBackCounts;
	}

	/**
	 * @param callBackPercentage the callBackPercentage to set
	 */
	public final void setCallBackPercentage(Double callBackPercentage) {
		this.callBackPercentage = callBackPercentage;
	}

	@Override
	public String toString() {
		return "MplaceCustCareRetentionReportVO [reportDate=" + reportDate + ", totalCallsCount=" + totalCallsCount
				+ ", totalUniqueCallCount=" + totalUniqueCallCount + ", callBackCounts=" + callBackCounts
				+ ", callBackPercentage=" + callBackPercentage + "]";
	}

}
