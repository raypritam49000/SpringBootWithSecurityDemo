package com.telemune.marketplace.rest.entity.vo;

import com.fasterxml.jackson.annotation.JsonInclude;
import com.fasterxml.jackson.annotation.JsonInclude.Include;

@JsonInclude(Include.NON_NULL)
public class PackAlertAnalyticsVO {

	private String alertDate;

	private Integer alertSent;

	private Integer packPurchased;
	
    private String msisdn;
	
	private String  packId;
	
	private String packPurchasedDate;

	/**
	 * @return the alertDate
	 */
	public String getAlertDate() {
		return alertDate;
	}

	/**
	 * @param alertDate the alertDate to set
	 */
	public void setAlertDate(String alertDate) {
		this.alertDate = alertDate;
	}

	/**
	 * @return the alertSent
	 */
	public Integer getAlertSent() {
		return alertSent;
	}

	/**
	 * @param alertSent the alertSent to set
	 */
	public void setAlertSent(Integer alertSent) {
		this.alertSent = alertSent;
	}

	/**
	 * @return the packPurchased
	 */
	public Integer getPackPurchased() {
		return packPurchased;
	}

	/**
	 * @param packPurchased the packPurchased to set
	 */
	public void setPackPurchased(Integer packPurchased) {
		this.packPurchased = packPurchased;
	}

	/**
	 * @return the msisdn
	 */
	public String getMsisdn() {
		return msisdn;
	}

	/**
	 * @param msisdn the msisdn to set
	 */
	public void setMsisdn(String msisdn) {
		this.msisdn = msisdn;
	}

	/**
	 * @return the packId
	 */
	public String getPackId() {
		return packId;
	}

	/**
	 * @param packId the packId to set
	 */
	public void setPackId(String packId) {
		this.packId = packId;
	}

	/**
	 * @return the packPurchasedDate
	 */
	public String getPackPurchasedDate() {
		return packPurchasedDate;
	}

	/**
	 * @param packPurchasedDate the packPurchasedDate to set
	 */
	public void setPackPurchasedDate(String packPurchasedDate) {
		this.packPurchasedDate = packPurchasedDate;
	}

	/* (non-Javadoc)
	 * @see java.lang.Object#toString()
	 */
	@Override
	public String toString() {
		return "PackAlertAnalyticsVO [alertDate=" + alertDate + ", alertSent=" + alertSent + ", packPurchased="
				+ packPurchased + ", msisdn=" + msisdn + ", packId=" + packId + ", packPurchasedDate="
				+ packPurchasedDate + "]";
	}
	
	
}
