package com.telemune.marketplace.rest.entity.embedded;

import java.io.Serializable;

import javax.persistence.Column;

public class WhiteBlack implements Serializable{
	/**
	 * @author mayank
	 */
	private static final long serialVersionUID = 1L;
	
	@Column(name = "MSISDN", nullable = false)
	private String msisdn;
	
    public WhiteBlack() {
		}
    
	public WhiteBlack(String msisdn) {
		
		this.msisdn = msisdn;
	}

	

	public String getMsisdn() {
		return msisdn;
	}

	public void setMsisdn(String msisdn) {
		this.msisdn = msisdn;
	}

	@Override
	public String toString() {
		return "WhiteBlack [msisdn=" + msisdn + ", getMsisdn()=" + getMsisdn() + ", getClass()=" + getClass()
				+ ", hashCode()=" + hashCode() + ", toString()=" + super.toString() + "]";
	}

	
	

	
	
}
