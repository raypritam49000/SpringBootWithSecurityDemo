@CrossOrigin(origins = "*", maxAge = 3600)
@RestController
@RequestMapping("/api/auth/promoServiceMap")
public class PromoServiceMapController {

	private static final Logger logger = Logger.getLogger(PromoServiceMapController.class);
	
	@Autowired
	IPromoServiceMap promoServiceMap;
	
	@GetMapping("/count/pagination/")
	public Response findListWithCountPagination() {

		try {
			
			System.out.println("inside the findListWithCountPagination() method pf Controller class");
			logger.info("inside findListWithCountPagination() method of PromoServiceMapController class");
	
			List<Object> promoServiceMapVOlst =null;
			 {
				
		System.out.println("inside the if of  findListWithCountPagination() method pf Controller class");

		List list = promoServiceMap.findAllCountWithPagination();
			
			if (list != null ) 
			{
				promoServiceMapVOlst = list;
				
			  //logger.debug(packTypeVOlst.toString());
				logger.info(promoServiceMapVOlst);
				logger.info("exit findListWithCountPagination() method of PromoServiceMapController class");
				return new Response(HttpStatus.OK, Constants.HTTP_STATUS_CODE_SCCUESS, promoServiceMapVOlst, "PromoServiceMap List",
						Constants.STATUS_SUCCESS, Constants.STATUS_SUCCESS_MESSAGE);
			    } 
			
			}	}
		catch (Exception exception) {
			logger.error(exception.toString());
			return new Response(HttpStatus.BAD_REQUEST, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
					exception.toString(), Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
		}
		return new Response(HttpStatus.NO_CONTENT, Constants.HTTP_STATUS_CODE_NO_CONTACT, new ArrayList<>(),
				"value not found", Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
	
	}
	
	@GetMapping("/promoServiceReport/download/promoService.csv")
	public void downloadPromoServiceMapCsv(HttpServletResponse response, @RequestParam("scope") String scope

	) throws IOException {

		logger.info("Inside downloadPromoServiceMapCsv() method of PromoServiceMapController class");
		logger.info("user input ==> --scope--" + scope);
		response.setContentType("text/csv");
		response.setHeader("Content-Disposition", "attachment; file=promoServiceReportCsv.csv");

		List<PromoServiceMapVO> promoServiceMapVOlst = promoServiceMap.promoServiceReportCsv(scope);
		logger.debug(promoServiceMapVOlst);

		if (promoServiceMapVOlst != null)
			CsvUtility.downloadPromoServiceReportCsv(response.getWriter(), promoServiceMapVOlst);
		logger.info("Exit downloadPromoServiceMapCsv() method of PromoServiceMapController class");
	}
	
	
	
	
			
	@DeleteMapping("/{msisdn}")
	public Response deleteByMsisdn(@PathVariable(name = "msisdn") String msisdn) {

		try {

			logger.info("inside deleteByMsisdn() method of PromoServiceMapController class");
			logger.info("Promopack deleted by msisdn ==>" + msisdn);
                     System.out.print("here is the msisdn we get"+msisdn);
			if (null != msisdn) {
				boolean isPromoServiceDeleted = promoServiceMap.promoDeleteMsisdn(msisdn);
				logger.debug("PromoService delete msisdn" + isPromoServiceDeleted);
				if (isPromoServiceDeleted) {
					logger.info("exit deleteByMsisdn() method of PromoServiceMapController class");
					return new Response(HttpStatus.NO_CONTENT, Constants.HTTP_STATUS_CODE_NO_CONTACT, new ArrayList<>(),
							"PromoPack deleted", Constants.STATUS_SUCCESS, Constants.STATUS_SUCCESS_MESSAGE);

				} else {
					logger.info("exit deleteByMsisdn() method of PromoServiceMapController class");
					return new Response(HttpStatus.BAD_GATEWAY, Constants.HTTP_STATUS_CODE_BAD_REQUEST,
							new ArrayList<>(), "PromoPlan is not deleted", Constants.STATUS_FAILURE,
							Constants.STATUS_FAILURE_MESSAGE);
				}

			} else {
				return new Response(HttpStatus.BAD_GATEWAY, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
						"PromoService is not deleted", Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
			}

		} catch (

		Exception exception) {
			logger.error(exception.toString());
			return new Response(HttpStatus.BAD_REQUEST, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
					exception.toString(), Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
		}

	}
	
	
	@PutMapping()
	public Response updatePromoService(@RequestBody PromoServiceMapVO promoServiceMapVO) {
		logger.info("Inside updatePlan() method of PromoServiceMapController class");
		logger.info("User input ==>" + promoServiceMapVO.toString());
		try {
			PromoServiceMapVO promoServiceMapVOdb = promoServiceMap.updatePromoService(promoServiceMapVO);
			logger.debug(promoServiceMapVOdb.toString());
			if (null != promoServiceMapVOdb && promoServiceMapVOdb.getMsisdn() != null) {
				logger.info("Exit updatePromoService() method of PromoServiceMapController class");
				return new Response(HttpStatus.OK, Constants.HTTP_STATUS_CODE_SCCUESS, new ArrayList<>(),
						"PromoPlan Updated", Constants.STATUS_SUCCESS, Constants.STATUS_SUCCESS_MESSAGE);
			} else {
				logger.info("Exit updatePromoService() method of PromoServiceMapController class");
				return new Response(HttpStatus.BAD_GATEWAY, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
						"PromoPlan is not updated", Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
			}
		} catch (Exception exception) {
			logger.error(exception.toString());
			exception.printStackTrace();
			return new Response(HttpStatus.BAD_REQUEST, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
					exception.toString(), Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
		}
	}

	@PostMapping()
	public Response addMsisdn(@RequestBody PromoServiceMapVO promoServiceMapVO) {
		logger.info("Inside addMsisdn() method of PromoServiceMapController class");
		logger.info("user input ==>" + promoServiceMapVO.toString());
		System.out.println("user input ==>" + promoServiceMapVO.toString());
		try {
			
			
			
			
			PromoServiceMapVO promoServiceMapVOdb = promoServiceMap.addMsisdn(promoServiceMapVO);
			logger.debug(promoServiceMapVOdb.toString());
			if (null != promoServiceMapVOdb && promoServiceMapVOdb.getMsisdn()!= null) {
				logger.info("Exit addMsisdn() method of PromoServiceMapController class");
				return new Response(HttpStatus.OK, Constants.HTTP_STATUS_CODE_SCCUESS, new ArrayList<>(),
						"Msisdn Added", Constants.STATUS_SUCCESS, Constants.STATUS_SUCCESS_MESSAGE);
			} else {
				logger.info("Exit addMsisdn() method of PromoServiceMapController class");
				return new Response(HttpStatus.BAD_GATEWAY, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
						"Msisdn is not added", Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
			}
		} catch (Exception exception) {
			exception.printStackTrace();
			logger.info(exception.toString());
			return new Response(HttpStatus.BAD_REQUEST, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
					exception.toString(), Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
		}
	}
	

	@GetMapping("/msisdn/")
	public Response findByMsisdn(@RequestParam("msisdn") String msisdn)
			 {
			System.out.println("inside findByMsisdn method");
		try {
			logger.info("Inside findByMsisdn() method of PromoServiceMapController class");
			logger.info("Msisdn ==>" + msisdn );
			PromoServiceMapVO promoServiceMapdb = null;
			List<PromoServiceMapVO> promoServiceMapVOlst = new ArrayList<>();
			
			promoServiceMapVOlst = promoServiceMap.findByMsisdn(msisdn);
				
				logger.debug(promoServiceMapVOlst.toString());
			
			if (null != promoServiceMapVOlst && !promoServiceMapVOlst.isEmpty()) {
				logger.info("Exit findByMsisdn() method of PromoServiceMapController class");
				return new Response(HttpStatus.OK, Constants.HTTP_STATUS_CODE_SCCUESS, promoServiceMapVOlst, "",
						Constants.STATUS_SUCCESS, Constants.STATUS_SUCCESS_MESSAGE);

			} else {
				logger.info("Exit findByMsisdn() method of PromoServiceMapController class");
				return new Response(HttpStatus.BAD_GATEWAY, Constants.HTTP_STATUS_CODE_BAD_REQUEST, promoServiceMapVOlst,
						"Not found value", Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
			}

		} catch (Exception exception) {
			logger.error(exception.toString());
			exception.printStackTrace();
			return new Response(HttpStatus.BAD_REQUEST, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(), "",
					Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
		}

	}

	
