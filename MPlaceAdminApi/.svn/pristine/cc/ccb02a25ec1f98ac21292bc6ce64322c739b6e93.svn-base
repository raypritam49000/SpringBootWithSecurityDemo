	  @PostMapping("/uploadFile/")  
	 // @RequestMapping(value = "/uploadFile/", method = RequestMethod.POST, consumes = "multipart/form-data" ,
     // produces = { "application/json", "application/xml" })
	    public Response handleFileUpload(@RequestParam("scope") String scope , @RequestParam("file") MultipartFile file, HttpSession session) {
		 try{
		  logger.info("Data found to upload");
		  System.out.println("inside the upload file method ");
		  	PromoServiceMapVO pVo=new PromoServiceMapVO();
		  	pVo.setScope(scope);
	     boolean added= promoServiceMap.store(file, pVo, session);
	       if(added){
	        return new Response(HttpStatus.OK, Constants.HTTP_STATUS_CODE_SCCUESS, new ArrayList<>(),
					"added Success", Constants.STATUS_SUCCESS, Constants.STATUS_SUCCESS_MESSAGE);
	    }  else{
	    	logger.info("Exit handleFileUpload() method of PromoServiceMapController class");
			return new Response(HttpStatus.BAD_GATEWAY, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
					"not added", Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
	    }
 		} catch(Exception exception){
 			exception.printStackTrace();
 			return new Response(HttpStatus.BAD_REQUEST, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
					exception.toString(), Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
 		}
		 }
	  
	  @DeleteMapping("/all/{scope}")
	  public Response deleteByScope(@PathVariable(name = "scope") String scope) {

			try {

				logger.info("inside deleteByScope() method of PromoServiceMapController class");
				logger.info("Promopack deleted by scope ==>" + scope);
	                     System.out.print("here is the scope we get"+scope);
				if (null != scope) {
					boolean isPromoServiceDeleted = promoServiceMap.deleteScope(scope);
					logger.debug("PromoService delete scope" + isPromoServiceDeleted);
					if (isPromoServiceDeleted) {
						logger.info("exit deleteByScope() method of PromoServiceMapController class");
						return new Response(HttpStatus.NO_CONTENT, Constants.HTTP_STATUS_CODE_NO_CONTACT, new ArrayList<>(),
								"PromoPack Scope deleted", Constants.STATUS_SUCCESS, Constants.STATUS_SUCCESS_MESSAGE);

					} else {
						logger.info("exit deleteByScope() method of PromoServiceMapController class");
						return new Response(HttpStatus.BAD_GATEWAY, Constants.HTTP_STATUS_CODE_BAD_REQUEST,
								new ArrayList<>(), "PromoPack Scope is not deleted", Constants.STATUS_FAILURE,
								Constants.STATUS_FAILURE_MESSAGE);
					}

				} else {
					return new Response(HttpStatus.BAD_GATEWAY, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
							"PromoPack Scope is not deleted", Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
				}

			} catch (

			Exception exception) {
				logger.error(exception.toString());
				return new Response(HttpStatus.BAD_REQUEST, Constants.HTTP_STATUS_CODE_BAD_REQUEST, new ArrayList<>(),
						exception.toString(), Constants.STATUS_FAILURE, Constants.STATUS_FAILURE_MESSAGE);
			}

		}
