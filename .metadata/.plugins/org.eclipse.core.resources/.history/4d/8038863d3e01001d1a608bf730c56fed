package com.employee.management.system.api.repo;

import java.util.Optional;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import com.employee.management.system.api.entity.Employee;

@Repository
public interface EmployeeRepository extends JpaRepository<Employee, Long> {
	public abstract Optional<Employee> findByUsername(String username);
	public abstract Boolean existsByUsername(String username);
	public abstract Boolean existsByEmail(String email);
}
