	public static Pack convertToPackVOToPack(PackVO packVO) {

		Pack pack = new Pack();
		// BeanUtils.copyProperties(pack, packVO);

		Optional.ofNullable(packVO.getAmountRequired()).ifPresent(pack::setAmountRequired);
		Optional.ofNullable(packVO.getCreateDate()).ifPresent(date -> {
			try {
				pack.setCreateDate(CommonUtility.stingDateConvertToSqlDate(date));
			} catch (ParseException e) {
				e.printStackTrace();
			}
		});
		// Optional.ofNullable(packVO.getEndDate()).ifPresent(ld->{
		// pack.setEndDate(CommonUtity.stingDateConvertToLocalDate(ld));

		// });
		Optional.ofNullable(packVO.getIsRenewEnable()).ifPresent(pack::setIsRenewEnable);
		Optional.ofNullable(packVO.getOther()).ifPresent(pack::setOther);
		Optional.ofNullable(packVO.getPriority()).ifPresent(pack::setPriority);
		Optional.ofNullable(packVO.getPromptFile()).ifPresent(pack::setPromptFile);
		Optional.ofNullable(packVO.getReminderTempId()).ifPresent(pack::setReminderTempId);
		Optional.ofNullable(packVO.getSpecialPackType()).ifPresent(pack::setSpecialPackType);
		Optional.ofNullable(packVO.getStartDate()).ifPresent(date -> {
			try {
				pack.setStartDate(CommonUtility.stingDateConvertToSqlDate(date));
			} catch (ParseException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
		});

		Optional.ofNullable(packVO.getEndDate()).ifPresent(date -> {
			try {
				pack.setEndDate(CommonUtility.stingDateConvertToSqlDate(date));
			} catch (ParseException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
		});

		// Optional.ofNullable(packVO.getStartDate()).ifPresent(ld->{
		// pack.setStartDate(CommonUtity.stingDateConvertToLocalDate(ld));

		// });
		Optional.ofNullable(packVO.getStatus()).ifPresent(pack::setStatus);
		Optional.ofNullable(packVO.getSubPackType()).ifPresent(pack::setSubPackType);
		Optional.ofNullable(packVO.getSubType()).ifPresent(pack::setSubType);
		Optional.ofNullable(packVO.getViewEnable()).ifPresent(pack::setViewEnable);
		Optional.ofNullable(packVO.getPackType()).ifPresent(pack::setPackType);

		return pack;
	}

